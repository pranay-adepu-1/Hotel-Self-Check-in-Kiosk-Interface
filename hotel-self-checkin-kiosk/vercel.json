{
  "version": 2,
  "public": true,
  "buildCommand": "npm install",
  "functions": {
    "api/index.js": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/((?!public/).*)", "destination": "/public/index.html" }
  ]
}
